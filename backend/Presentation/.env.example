# Database connection string (e.g. Host=localhost;Port=5432;Database=cafe_lumiere;Username=postgres;Password=yourpassword)
DEFAULTCONNECTION=

# JWT configuration
JWT_SECRET_KEY=        # Strong random secret key
JWT_ISSUER=            # App/domain issuing the token (e.g. https://yourapp.com)
JWT_AUDIENCE=          # Intended audience (e.g. https://yourapp.com)
JWT_LIFETIME_MINUTES=  # Token expiration time in minutes (e.g. 60)

# CORS allowed origin(s) (e.g. http://localhost:3000)
CORS_ORIGIN=